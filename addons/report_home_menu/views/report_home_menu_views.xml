<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <menuitem
        id="menu_report_home_root"
        name="Reporting Setting"
        sequence="145"
        web_icon="report_home_menu,static/description/icon.svg"
    />

    <menuitem
        id="menu_report_home_reporting"
        name="Reporting"
        parent="menu_report_home_root"
        sequence="10"
    />

    <record id="menu_report_home_root" model="ir.ui.menu">
        <field name="groups_id" eval="[Command.set([ref('report_home_menu.group_reporting_setting_admin')])]" />
    </record>

    <record id="menu_report_home_reporting" model="ir.ui.menu">
        <field name="active" eval="False" />
        <field name="groups_id" eval="[Command.set([ref('report_home_menu.group_reporting_setting_admin')])]" />
    </record>

    <function model="ir.ui.menu" name="sync_reporting_setting_menus" />
</odoo>
